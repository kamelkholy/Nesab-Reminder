# MongoDB connection string (use Azure Cosmos DB for MongoDB in production)
MONGODB_URI=mongodb://localhost:27017/nesab-reminder

# Server port (Azure sets this automatically via PORT)
PORT=3001

# Authentication - CHANGE THESE IN PRODUCTION
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_SECRET=change-this-to-a-long-random-string

# Azure Communication Services (for email reminders)
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=
EMAIL_TO=
